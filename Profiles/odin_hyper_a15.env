CONFIG_ENV=Profiles/odin_hyper_a15.env

DEVICE_NAME=xiaomi_mix_4
DEVICE_CODENAME=odin

CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-
EXTRA_CMDS:LD=ld.lld LLVM=1 LLVM_IAS=1

KERNEL_SOURCE=https://github.com/MrNya907/xiaomi_kernel_odin_mix4
KERNEL_BRANCH=master
CLANG_SOURCE=https://github.com/ruoqing501/clang-r383902b1.git
CLANG_BRANCH=

GCC_GNU=true
GCC_64_SOURCE=
GCC_64_BRANCH=
GCC_32_SOURCE=
GCC_32_BRANCH=

DEFCONFIG_SOURCE=
DEFCONFIG_NAME=odin_defconfig
DEFCONFIG_ORIGIN_DEFCONFIG=

KERNELSU_SOURCE=https://github.com/ShirkNeko/SukiSU-Ultra.git
KERNELSU_BRANCH=nongki
KERNELSU_NAME=SukiSU-Ultra

SUSFS_ENABLE=true
SUSFS_FIXED=true

AK3_SOURCE=https://github.com/osm0sis/AnyKernel3.git
AK3_BRANCH=master

BOOT_SOURCE=

LXC_ENABLE=false

HAVE_NO_DTBO=false
HAVE_NO_DTBO_TOOL=false

ROM_TEXT=hyperos_android15
